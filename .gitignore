*.key
*.pem
secrets/

# ── Build Output ──
dist/
build/
.next/
out/

# ── OS Files ──
.DS_Store
Thumbs.db
*.swp
*~

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE / Editor ──
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Testing ──
coverage/
.nyc_output/

# ── Cache ──
.cache/
.parcel-cache/
.eslintcache

# ── PWA / Service Worker Dev ──
sw-precache-config.js

# ── POI Data (large datasets) ──
data/raw/
*.geojson.bak
poi-exports/

# ── Audio Cache (ElevenLabs TTS) ──
audio-cache/
*.mp3
*.wav
!assets/audio/*.mp3

# ── Vercel / Deployment ──
.vercel/
.netlify/
